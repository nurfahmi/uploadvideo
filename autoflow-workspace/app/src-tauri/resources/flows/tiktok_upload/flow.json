{
  "name": "TikTok Upload",
  "platform": "tiktok",
  "batch": true,
  "batch_fields": [
    { "key": "video_path", "label": "Video File", "required": true, "placeholder": "/path/to/video.mp4" },
    { "key": "caption", "label": "Caption", "placeholder": "Write caption..." },
    { "key": "hashtags", "label": "Hashtags", "placeholder": "#fyp #viral" },
    { "key": "product_url", "label": "Product URL", "placeholder": "https://shop.tiktok.com/..." }
  ],
  "steps": [
    { "action": "kill_app", "package": "com.zhiliaoapp.musically", "description": "Force stop TikTok" },
    { "action": "push_file", "local_path": "{{video_path}}", "remote_path": "/sdcard/DCIM/AutoFlow/", "description": "Push video to device", "stop_on_fail": true },
    { "action": "media_scan", "path": "/sdcard/DCIM/AutoFlow/", "description": "Refresh media gallery" },
    { "action": "wait", "duration": 2, "description": "Wait for media scan" },
    { "action": "open_app", "package": "com.zhiliaoapp.musically", "description": "Open TikTok" },
    { "action": "wait", "duration": 4, "description": "Wait for app to load" },
    { "action": "click", "target": "btn_create.png", "description": "Tap + (create) button", "timeout": 15 },
    { "action": "wait", "duration": 2, "description": "Wait for camera screen" },
    { "action": "click", "target": "btn_upload.png", "description": "Tap Upload to open gallery", "timeout": 10 },
    { "action": "wait", "duration": 3, "description": "Wait for gallery" },
    { "action": "click", "target": "video_thumbnail.png", "description": "Select video from gallery", "timeout": 10, "optional": true },
    { "action": "click", "target": "btn_next.png", "description": "Tap Next", "timeout": 10 },
    { "action": "wait", "duration": 3, "description": "Wait for editor" },
    { "action": "click", "target": "btn_next_edit.png", "description": "Skip editing, tap Next", "timeout": 15, "optional": true },
    { "action": "wait", "duration": 2, "description": "Wait for post screen" },
    { "action": "click", "target": "caption_field.png", "description": "Tap caption field", "timeout": 10 },
    { "action": "type_text", "text": "{{caption}} {{hashtags}}", "description": "Type caption and hashtags" },
    { "action": "click", "target": "btn_add_link.png", "description": "Tap add product link", "timeout": 5, "optional": true },
    { "action": "type_text", "text": "{{product_url}}", "description": "Paste product URL", "optional": true },
    { "action": "click", "target": "btn_confirm_link.png", "description": "Confirm product link", "timeout": 5, "optional": true },
    { "action": "click", "target": "btn_post.png", "description": "Tap Post", "timeout": 10 },
    { "action": "wait", "duration": 5, "description": "Wait for upload to start" },
    { "action": "click", "target": "upload_complete.png", "description": "Wait for upload confirmation", "timeout": 120, "optional": true }
  ]
}
