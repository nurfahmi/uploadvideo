{
  "name": "Shopee Video Upload",
  "platform": "shopee",
  "batch": true,
  "device_profile": {
    "model": "Samsung SM-A057F (Galaxy A05s)",
    "resolution": "1080x2400",
    "density": 450,
    "android": 15
  },
  "batch_fields": [
    { "key": "video_path", "label": "Video File", "required": true },
    { "key": "caption", "label": "Caption", "placeholder": "Deskripsi produk..." },
    { "key": "hashtags", "label": "Hashtags", "placeholder": "#shopee #promo" },
    { "key": "affiliate_link", "label": "Affiliate Link", "placeholder": "https://shopee.co.id/...", "required": false }
  ],
  "steps": [
    { "_phase": "A", "_title": "=== PREPARATION ===" },
    {
      "action": "kill_app",
      "package": "com.shopee.id",
      "description": "Kill Shopee"
    },
    {
      "action": "shell_cmd",
      "command": "rm -f /sdcard/DCIM/AutoFlow/*",
      "description": "Clear old videos from device"
    },
    {
      "action": "push_file",
      "local_path": "{{video_path}}",
      "remote_path": "/sdcard/DCIM/AutoFlow/",
      "description": "Push video to device",
      "stop_on_fail": true
    },
    {
      "action": "media_scan",
      "path": "/sdcard/DCIM/AutoFlow/",
      "description": "Refresh media gallery"
    },
    { "action": "wait", "duration": 2, "description": "Wait media scan" },

    { "_phase": "B", "_title": "=== LAUNCH & NAVIGATE ===" },
    {
      "action": "launch_intent",
      "intent": "-n com.shopee.id/com.shopee.app.ui.home.HomeActivity_",
      "description": "Launch Shopee",
      "wait_for": "HomeActivity",
      "wait_timeout": 10,
      "retry": 2
    },
    {
      "action": "tap", "x": 108, "y": 2178,
      "description": "Tap Beranda (reset tab)",
      "delay_after": 2
    },
    {
      "action": "tap", "x": 972, "y": 2178,
      "description": "Tap Saya (Profile)",
      "delay_after": 3
    },

    { "_phase": "C", "_title": "=== PROFILE → VIDEO ===" },
    {
      "action": "scroll_to", "direction": "up", "times": 1,
      "description": "Scroll down Profile",
      "delay_after": 1
    },
    {
      "action": "tap", "x": 287, "y": 1240,
      "description": "Tap Live dan Video",
      "delay_after": 3
    },
    {
      "action": "tap", "x": 540, "y": 299,
      "description": "Tap tab Video",
      "delay_after": 2
    },

    { "_phase": "D", "_title": "=== POST VIDEO → GALLERY ===" },
    {
      "action": "tap", "x": 586, "y": 2090,
      "description": "Tap Post Video",
      "delay_after": 3
    },
    {
      "action": "tap", "x": 862, "y": 1832,
      "description": "Tap Galeri",
      "delay_after": 3
    },

    { "_phase": "E", "_title": "=== SELECT VIDEO ===" },
    {
      "action": "tap", "x": 540, "y": 296,
      "description": "Tap Video filter",
      "delay_after": 1
    },
    {
      "action": "tap", "x": 134, "y": 495,
      "description": "Select video pertama",
      "delay_after": 1
    },
    {
      "action": "tap", "x": 888, "y": 2143,
      "description": "Tap Lanjutkan (preview)",
      "delay_after": 3
    },

    { "_phase": "F", "_title": "=== EDITOR → POST FORM (smart wait) ===" },
    {
      "action": "tap", "x": 905, "y": 2130,
      "description": "Tap Lanjutkan editor → wait PublishVideoActivity",
      "wait_for": "PublishVideoActivity",
      "wait_timeout": 25,
      "retry": 3
    },

    { "_phase": "G", "_title": "=== CAPTION via uiautomator2 ===" },
    {
      "action": "wait", "duration": 2,
      "description": "Wait post form settle"
    },
    {
      "action": "u2_click",
      "textContains": "Tambah keterangan",
      "description": "Focus caption field (uiautomator2)",
      "timeout": 10,
      "delay_after": 1
    },
    {
      "action": "type_text",
      "text": "{{caption}} {{hashtags}}",
      "description": "Type caption + hashtags"
    },
    {
      "action": "key_event", "keycode": "back",
      "description": "Dismiss keyboard",
      "delay_after": 1
    },
    {
      "action": "tap", "x": 1020, "y": 73,
      "description": "Tap OK konfirmasi caption",
      "delay_after": 2
    },

    { "_phase": "G2", "_title": "=== AFFILIATE PRODUCT (optional) ===" },
    {
      "action": "skip_if_empty",
      "field": "affiliate_link",
      "skip_to_phase": "H",
      "description": "Skip affiliate if no link provided"
    },
    {
      "action": "tap", "x": 1030, "y": 735,
      "description": "Tap Tambah Produk (arrow area)",
      "delay_after": 3
    },
    {
      "action": "tap", "x": 1001, "y": 135,
      "description": "Tap link icon (top-right Import Link)",
      "delay_after": 2
    },
    {
      "action": "u2_click",
      "textContains": "link produk Shopee",
      "description": "Focus Link Produk text area",
      "timeout": 5,
      "delay_after": 1
    },
    {
      "action": "type_text",
      "text": "{{affiliate_link}}",
      "description": "Type affiliate link"
    },
    {
      "action": "u2_click",
      "text": "Import",
      "description": "Tap Import button",
      "timeout": 5,
      "delay_after": 3
    },
    {
      "action": "tap", "x": 60, "y": 1399,
      "description": "Select product checkbox",
      "delay_after": 1
    },
    {
      "action": "u2_click",
      "textContains": "Tambah",
      "description": "Tap Tambah to add product",
      "timeout": 5,
      "delay_after": 3
    },

    { "_phase": "H", "_title": "=== PUBLISH ===" },
    {
      "action": "screenshot",
      "output": "_debug_before_publish.png",
      "description": "Screenshot before publish",
      "optional": true
    },
    {
      "action": "tap", "x": 540, "y": 2130,
      "description": "Tap Posting",
      "delay_after": 15
    },
    {
      "action": "screenshot",
      "output": "_debug_after_publish.png",
      "description": "Screenshot after publish",
      "optional": true
    },

    { "_phase": "I", "_title": "=== CLEANUP ===" },
    {
      "action": "kill_app",
      "package": "com.shopee.id",
      "description": "Close Shopee (clean state for next task)"
    }
  ]
}
