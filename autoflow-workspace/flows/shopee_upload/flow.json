{
  "name": "Shopee Video Upload",
  "platform": "shopee",
  "batch": true,
  "device_profile": {
    "model": "Samsung SM-A057F (Galaxy A05s)",
    "resolution": "1080x2400",
    "density": 450,
    "android": 15
  },
  "batch_fields": [
    { "key": "video_path", "label": "Video File", "required": true },
    { "key": "caption", "label": "Caption", "placeholder": "Deskripsi produk..." },
    { "key": "hashtags", "label": "Hashtags", "placeholder": "#shopee #promo" },
    { "key": "affiliate_link", "label": "Affiliate Link", "placeholder": "https://shopee.co.id/...", "required": false }
  ],
  "steps": [
    { "_phase": "A", "_title": "=== PREPARATION ===" },
    {
      "action": "kill_app",
      "package": "com.shopee.id",
      "description": "Kill Shopee"
    },
    {
      "action": "shell_cmd",
      "command": "rm -f /sdcard/DCIM/AutoFlow/*",
      "description": "Clear old videos from device"
    },
    {
      "action": "push_file",
      "local_path": "{{video_path}}",
      "remote_path": "/sdcard/DCIM/AutoFlow/",
      "description": "Push video to device",
      "stop_on_fail": true
    },
    {
      "action": "media_scan",
      "path": "/sdcard/DCIM/AutoFlow/",
      "description": "Refresh media gallery"
    },
    { "action": "wait", "duration": 2, "description": "Wait media scan" },

    { "_phase": "B", "_title": "=== LAUNCH & NAVIGATE ===" },
    {
      "action": "launch_intent",
      "intent": "-n com.shopee.id/com.shopee.app.ui.home.HomeActivity_",
      "description": "Launch Shopee",
      "wait_for": "HomeActivity",
      "wait_timeout": 10,
      "retry": 2
    },
    {
      "action": "u2_click",
      "resourceId": "com.shopee.id:id/icon",
      "contentDescription": "tab_bar_button_home",
      "description": "Tap Beranda (reset tab)",
      "fallback_tap_pct": { "x_pct": 0.1, "y_pct": 0.908 },
      "delay_after": 2
    },
    {
      "action": "u2_click",
      "resourceId": "com.shopee.id:id/icon",
      "contentDescription": "tab_bar_button_me",
      "description": "Tap Saya (Profile)",
      "fallback_tap_pct": { "x_pct": 0.9, "y_pct": 0.908 },
      "delay_after": 3
    },

    { "_phase": "C", "_title": "=== PROFILE → VIDEO ===" },
    {
      "action": "scroll_to", "direction": "up", "times": 1,
      "description": "Scroll down Profile",
      "delay_after": 1
    },
    {
      "action": "u2_click",
      "textContains": "Live dan Video",
      "description": "Tap Live dan Video",
      "fallback_tap_pct": { "x_pct": 0.266, "y_pct": 0.517 },
      "delay_after": 3
    },
    {
      "action": "u2_click",
      "text": "Video",
      "description": "Tap tab Video",
      "fallback_tap_pct": { "x_pct": 0.5, "y_pct": 0.125 },
      "delay_after": 2
    },

    { "_phase": "D", "_title": "=== POST VIDEO → GALLERY ===" },
    {
      "action": "u2_click",
      "textContains": "Post Video",
      "description": "Tap Post Video",
      "fallback_tap_pct": { "x_pct": 0.543, "y_pct": 0.871 },
      "delay_after": 3
    },
    {
      "action": "u2_click",
      "resourceId": "com.shopee.id:id/iv_album_icon",
      "description": "Tap Galeri",
      "fallback_tap_pct": { "x_pct": 0.799, "y_pct": 0.763 },
      "delay_after": 3
    },

    { "_phase": "E", "_title": "=== SELECT VIDEO ===" },
    {
      "action": "u2_click",
      "text": "Video",
      "description": "Tap Video filter",
      "fallback_tap_pct": { "x_pct": 0.5, "y_pct": 0.123 },
      "delay_after": 1
    },
    {
      "action": "tap_pct",
      "x_pct": 0.124,
      "y_pct": 0.206,
      "description": "Select first video (grid)",
      "delay_after": 1
    },
    {
      "action": "u2_click",
      "text": "Lanjutkan",
      "description": "Tap Lanjutkan (preview)",
      "fallback_tap_pct": { "x_pct": 0.822, "y_pct": 0.893 },
      "wait_for": "SSZBasePreviewActivity",
      "wait_timeout": 20,
      "retry": 2,
      "delay_after": 3
    },

    { "_phase": "F", "_title": "=== EDITOR → POST FORM ===" },
    {
      "action": "u2_click",
      "resourceId": "com.shopee.id:id/tv_compress",
      "text": "Lanjutkan",
      "description": "Tap Lanjutkan editor → PublishVideoActivity",
      "fallback_tap_pct": { "x_pct": 0.838, "y_pct": 0.888 },
      "wait_for": "PublishVideoActivity",
      "wait_timeout": 25,
      "retry": 3
    },

    { "_phase": "G", "_title": "=== CAPTION ===" },
    {
      "action": "wait", "duration": 2,
      "description": "Wait post form settle"
    },
    {
      "action": "u2_click",
      "resourceId": "com.shopee.id.dfpluginshopee16:id/et_caption",
      "textContains": "Tambah keterangan",
      "description": "Focus caption field",
      "fallback_tap_pct": { "x_pct": 0.45, "y_pct": 0.15 },
      "timeout": 10,
      "delay_after": 1
    },
    {
      "action": "u2_type",
      "resourceId": "com.shopee.id.dfpluginshopee16:id/et_caption",
      "text": "{{caption}}",
      "clear": true,
      "description": "Type caption",
      "delay_after": 2
    },
    {
      "action": "u2_type",
      "resourceId": "com.shopee.id.dfpluginshopee16:id/et_caption",
      "text": " {{hashtags}}",
      "clear": false,
      "description": "Append hashtags",
      "delay_after": 2
    },
    {
      "action": "key_event", "keycode": "back",
      "description": "Dismiss keyboard",
      "delay_after": 1
    },
    {
      "action": "u2_click",
      "resourceId": "com.shopee.id.dfpluginshopee16:id/tv_right",
      "text": "OK",
      "description": "Tap OK konfirmasi caption",
      "fallback_tap_pct": { "x_pct": 0.944, "y_pct": 0.030 },
      "delay_after": 2
    },

    { "_phase": "G2", "_title": "=== AFFILIATE PRODUCT (optional) ===" },
    {
      "action": "skip_if_empty",
      "field": "affiliate_link",
      "skip_to_phase": "H",
      "description": "Skip affiliate if no link provided"
    },
    {
      "action": "u2_click",
      "resourceId": "com.shopee.id.dfpluginshopee16:id/tv_add_product_tip",
      "textContains": "Tambah Produk",
      "description": "Tap Tambah Produk",
      "fallback_tap_pct": { "x_pct": 0.954, "y_pct": 0.306 },
      "delay_after": 3
    },
    {
      "action": "tap_pct",
      "x_pct": 0.928,
      "y_pct": 0.056,
      "description": "Tap link icon (top-right Import Link)",
      "delay_after": 2
    },
    {
      "action": "u2_click",
      "textContains": "link produk Shopee",
      "description": "Focus Link Produk text area",
      "fallback_tap_pct": { "x_pct": 0.5, "y_pct": 0.2 },
      "timeout": 5,
      "delay_after": 1
    },
    {
      "action": "u2_type",
      "className": "android.widget.EditText",
      "text": "{{affiliate_link}}",
      "clear": true,
      "description": "Type affiliate link",
      "delay_after": 2
    },
    {
      "action": "u2_click",
      "text": "Import",
      "description": "Tap Import button",
      "fallback_tap_pct": { "x_pct": 0.5, "y_pct": 0.42 },
      "timeout": 5,
      "delay_after": 3
    },
    {
      "action": "tap_pct",
      "x_pct": 0.056,
      "y_pct": 0.583,
      "description": "Select product checkbox",
      "delay_after": 1
    },
    {
      "action": "u2_click",
      "textContains": "Tambah",
      "description": "Tap Tambah to add product",
      "fallback_tap_pct": { "x_pct": 0.63, "y_pct": 0.88 },
      "timeout": 5,
      "delay_after": 3
    },

    { "_phase": "H", "_title": "=== PUBLISH ===" },
    {
      "action": "screenshot",
      "output": "_debug_before_publish.png",
      "description": "Screenshot before publish",
      "optional": true
    },
    {
      "action": "u2_click",
      "resourceId": "com.shopee.id.dfpluginshopee16:id/btn_post",
      "text": "Posting",
      "description": "Tap Posting",
      "fallback_tap_pct": { "x_pct": 0.5, "y_pct": 0.888 },
      "wait_for": "HomeActivity",
      "wait_timeout": 20,
      "retry": 2,
      "delay_after": 15
    },
    {
      "action": "screenshot",
      "output": "_debug_after_publish.png",
      "description": "Screenshot after publish",
      "optional": true
    },

    { "_phase": "I", "_title": "=== CLEANUP ===" },
    {
      "action": "kill_app",
      "package": "com.shopee.id",
      "description": "Close Shopee (clean state for next task)"
    }
  ]
}
