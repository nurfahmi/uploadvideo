{
  "name": "ITel (from template)",
  "platform": "shopee",
  "batch": true,
  "notes": "Converted from template ITel",
  "batch_fields": [
    {
      "key": "affiliate_link",
      "label": "affiliate_link",
      "required": false
    },
    {
      "key": "caption",
      "label": "caption",
      "required": true
    },
    {
      "key": "hashtags",
      "label": "hashtags",
      "required": false
    }
  ],
  "steps": [
    {
